# Copy to .env and fill in values. Never commit .env.

# Postgres (Neon, Supabase, Railway, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth v5 — required for sign-in (use a long random string, e.g. openssl rand -base64 32)
AUTH_SECRET="replace-with-long-random-secret"
# Optional: app URL (Vercel sets automatically in prod)
# AUTH_URL="http://localhost:3000"

# Comma-separated emails that receive UserAppRole ADMIN on first registration (commissioner tools).
# Everyone else registers as PLAYER. Admins can still join leagues and own teams.
# ADMIN_EMAILS="you@example.com,cofounder@example.com"

# Optional: licensed cricket / schedule API
# CRICKET_DATA_API_KEY=""

# Server time: use UTC in DB and jobs; UI shows local via Intl.
# TZ is optional for local scripts
# TZ=UTC
