# Copy to .env and fill in values. Never commit .env.

# Postgres (Neon, Supabase, Railway, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth — choose one stack (NextAuth, Auth.js, Clerk, etc.); placeholders for Phase 1
# AUTH_SECRET="generate-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"

# Optional: licensed cricket / schedule API
# CRICKET_DATA_API_KEY=""

# Server time: use UTC in DB and jobs; UI shows local via Intl.
# TZ is optional for local scripts
# TZ=UTC
